# ──────────────────────────────────────────────────────────────
# Artezan Frontend — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# ──────────────────────────────────────────────────────────────

# Backend API base URL (no trailing slash)
# Development default: http://localhost:8080/api/v1
# Production example:  https://api.artezans.com/api/v1
VITE_API_URL=http://localhost:8080/api/v1

# Stripe publishable key (from https://dashboard.stripe.com/apikeys)
# Use the 'pk_test_...' key for development/staging
# Use the 'pk_live_...' key for production
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_publishable_key_here

# App environment label (optional, used for conditional UI hints)
# Values: development | staging | production
VITE_APP_ENV=development
