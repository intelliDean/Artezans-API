# ─────────────────────────────────────────────────────────────────────────────
# Artezans — local development environment variables
# Copy this file to .env and fill in your values.
# .env is git-ignored. Never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=artezans
DB_USERNAME=postgres
DB_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be a Base64-encoded key of at least 512 bits (64+ random bytes).
# Generate one: openssl rand -base64 64
JWT_SECRET=

# ── Token expiry (hours) ──────────────────────────────────────────────────────
ACCESS_EXPIRATION=3
REFRESH_EXPIRATION=168

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=Artezans
APP_EMAIL=info@artezans.com
FRONTEND_URL=http://localhost:3000
CHARGES=0.15

# ── Brevo (email + SMS) ───────────────────────────────────────────────────────
BREVO_API_KEY=
MAIL_URL=https://api.brevo.com/v3/smtp/email
SMS_URL=https://api.brevo.com/v3/transactionalSMS/sms

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_NAME=
CLOUDINARY_KEY=
CLOUDINARY_SECRET=

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=

# ── PayPal ────────────────────────────────────────────────────────────────────
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_SUCCESS_URL=http://localhost:8080/api/v1/paypal/success
PAYPAL_CANCEL_URL=http://localhost:8080/api/v1/paypal/cancel

# ── OAuth2 ────────────────────────────────────────────────────────────────────
OAUTH2_REDIRECT_URI=http://localhost:8080/login/oauth2/code/*
